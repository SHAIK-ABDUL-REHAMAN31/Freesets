# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Freesets

# ─────────────────────────────────────────────
# Cloudinary (per-category accounts)
# ─────────────────────────────────────────────

# Cloudinary — AI Images
CLOUDINARY_AI_IMAGES_CLOUD_NAME=
CLOUDINARY_AI_IMAGES_API_KEY=
CLOUDINARY_AI_IMAGES_API_SECRET=

# Cloudinary — Product Shoot
CLOUDINARY_PRODUCT_SHOOT_CLOUD_NAME=
CLOUDINARY_PRODUCT_SHOOT_API_KEY=
CLOUDINARY_PRODUCT_SHOOT_API_SECRET=

# Cloudinary — Video Prompts
CLOUDINARY_VIDEO_PROMPTS_CLOUD_NAME=
CLOUDINARY_VIDEO_PROMPTS_API_KEY=
CLOUDINARY_VIDEO_PROMPTS_API_SECRET=

# Cloudinary — Portrait & Headshot
CLOUDINARY_PORTRAIT_CLOUD_NAME=
CLOUDINARY_PORTRAIT_API_KEY=
CLOUDINARY_PORTRAIT_API_SECRET=

# Cloudinary — Architecture & Interior
CLOUDINARY_ARCHITECTURE_CLOUD_NAME=
CLOUDINARY_ARCHITECTURE_API_KEY=
CLOUDINARY_ARCHITECTURE_API_SECRET=

# Cloudinary — Food & Drink
CLOUDINARY_FOOD_DRINK_CLOUD_NAME=
CLOUDINARY_FOOD_DRINK_API_KEY=
CLOUDINARY_FOOD_DRINK_API_SECRET=

# Cloudinary — Logo & Brand
CLOUDINARY_LOGO_BRAND_CLOUD_NAME=
CLOUDINARY_LOGO_BRAND_API_KEY=
CLOUDINARY_LOGO_BRAND_API_SECRET=

# Cloudinary — Texture & Background
CLOUDINARY_TEXTURE_CLOUD_NAME=
CLOUDINARY_TEXTURE_API_KEY=
CLOUDINARY_TEXTURE_API_SECRET=

# Cloudinary — Fashion & Style
CLOUDINARY_FASHION_CLOUD_NAME=
CLOUDINARY_FASHION_API_KEY=
CLOUDINARY_FASHION_API_SECRET=

# Cloudinary — Wallpaper & Poster
CLOUDINARY_WALLPAPER_CLOUD_NAME=
CLOUDINARY_WALLPAPER_API_KEY=
CLOUDINARY_WALLPAPER_API_SECRET=

# Cloudinary — Movie & Cinema
CLOUDINARY_MOVIE_CLOUD_NAME=
CLOUDINARY_MOVIE_API_KEY=
CLOUDINARY_MOVIE_API_SECRET=

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Admin (Secret — pick your own values)
# ─────────────────────────────────────────────
ADMIN_SECRET_PATH=              # e.g. freesets-hq  (the secret URL path)
ADMIN_USERNAME=                 # your admin username
ADMIN_PASSWORD=                 # your admin password
ADMIN_SESSION_SECRET=           # run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXT_PUBLIC_ADMIN_PATH=         # must match /ADMIN_SECRET_PATH  (e.g. /freesets-hq)
